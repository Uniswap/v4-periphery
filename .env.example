# Copy to .env (gitignored). Never put a raw private key here — import it once into an encrypted
# keystore instead and pass `--account <name>` to forge script / cast:
#   cast wallet import swap-and-add-deployer --interactive

# Archive RPC for reproducible fork tests (public endpoints serve no archive state)
SEPOLIA_FORK_URL=
FORK_URL=
FORK_BLOCK=

# foundry.toml [rpc_endpoints] mainnet alias
INFURA_API_KEY=

# Trading API (route generation for SwapAndAdd integration tests)
TAPI_API_KEY=
# Deep Sepolia v3 route venues: UNI/WETH 0.3% 0x287B0e934ed0439E2a7b1d5F0FC25eA2c24b64f7,
# USDC/WETH 0.05% 0x3289680dD4d6C10bb19b899729cda5eEF58AEfF1 (verified onchain 2026-07-15)
